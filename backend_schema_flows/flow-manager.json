        "name": "Run Script",
        "key": "run_script",
        "type": "exec",
        "position_x": 38,
        "position_y": 2,
        "options": {
          "code": "module.exports = async function(data) {\n    const trigger = data.$trigger;\n\n    if (!trigger || !trigger.body || !trigger.headers) {\n        throw new Error(\"Validation Failed: Malformed webhook structure.\");\n    }\n\n    const expectedToken = data.read_payment_settings[0].webhook_verification_token;\n    const incomingToken = trigger.headers['x-callback-token'];\n\n    if (incomingToken !== expectedToken) {\n        throw new Error(\"Security Alert: Invalid Xendit Callback Token.\");\n    }\n\n    if (trigger.body.status !== \"PAID\") {\n        throw new Error(`Ignored Webhook: Invoice status is '${trigger.body.status}', expected 'PAID'.`);\n    }\n\n    if (!trigger.body.external_id || !trigger.body.paid_amount) {\n        throw new Error(\"Validation Failed: Missing required fields (external_id or paid_amount).\");\n    }\n\n    const category = trigger.body.items?.[0]?.category || '';\n\n    return {\n        dateNow: new Date(),\n        isValid: true,\n        referenceId: trigger.body.external_id,\n        amount: trigger.body.paid_amount,\n        paymentMethod: trigger.body.payment_method,\n        timestamp: trigger.body.paid_at,\n        category,\n    };\n};"
