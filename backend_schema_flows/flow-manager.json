        "club"
      ]
    },
    "operation": "851c41dd-c4c0-4862-9b1d-d3618c05fdea",
    "operations": [
      {
        "id": "3e3081eb-3899-498b-9761-e95993984be8",
        "name": "trigger update player rating",
        "key": "trigger_update_player_rating",
        "type": "trigger",
        "position_x": 37,
        "position_y": 1,
        "options": {
          "iterationMode": "parallel",
          "payload": "{{get_players}}",
          "flow": "8f57fd7e-e49c-4440-9b41-304d1dd0c577"
        },
        "resolve": null,
        "reject": null
      },
      {
        "id": "851c41dd-c4c0-4862-9b1d-d3618c05fdea",
        "name": "get players",
        "key": "get_players",
        "type": "exec",
        "position_x": 19,
        "position_y": 1,
        "options": {
          "code": "module.exports = async function(data) {\n    const mm = data.$trigger?.payload?.appState?.matchmaking;\n    if (!mm?.players || !mm?.completedMatches) return [];\n\n    const { players, completedMatches } = mm;\n    const result = [];\n\n    const matchPayloads = {};\n    for (const match of completedMatches) {\n        const key = `${match.completedAt}_${match.matchId}`;\n        const playerIds = new Set();\n        const collect = (team) => {\n            if (!team) return;\n            for (const { username } of team) {\n                const p = players[username];\n                if (p?.userId) playerIds.add(p.userId);\n            }\n        };\n        collect(match.teamA);\n        collect(match.teamB);\n\n        matchPayloads[key] = {\n            match_key: key,\n            match_id: match.matchId,\n            match_type: match.matchType,\n            team_a: match.teamA,\n            team_b: match.teamB,\n            team_a_score: match.teamAScore,\n            team_b_score: match.teamBScore,\n            started_at: match.startedAt ? new Date(match.startedAt).toISOString() : null,\n            completed_at: new Date(match.completedAt).toISOString(),\n            players: Array.from(playerIds, id => ({ directus_users_id: id }))\n        };\n    }\n\n    const processTeam = (team, key) => {\n        if (!team) return;\n        for (const { username } of team) {\n            const player = players[username];\n            if (!player?.userId) continue;\n            if (!player.completed_matches) {\n                player.completed_matches = [];\n                result.push(player);\n            }\n            player.completed_matches.push(matchPayloads[key]);\n        }\n    };\n\n    for (const match of completedMatches) {\n        const key = `${match.completedAt}_${match.matchId}`;\n        processTeam(match.teamA, key);\n        processTeam(match.teamB, key);\n    }\n\n    return result;\n};"
        },
        "resolve": "3e3081eb-3899-498b-9761-e95993984be8",
        "reject": null
      }
    ],
    "flow_manager_category": null,
    "accountability": "all"
  },
