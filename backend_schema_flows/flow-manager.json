      {
        "id": "aa4bf6e3-acdf-483f-bed4-0bc160e83a2d",
        "name": "script transform player to event",
        "key": "script_transform_player_to_event",
        "type": "exec",
        "position_x": 38,
        "position_y": 1,
        "options": {
          "code": "module.exports = async function(data) {\n    const player = data.$trigger;\n    const user = data.read_user;\n\n    // 1. Validate player exists first\n    if (!player || !player.userId) {\n        throw new Error('Player must have a user account');\n    }\n    \n    const totalMatches = (player.wins || 0) + (player.losses || 0);\n    if (totalMatches === 0) {\n        throw new Error('Player must have at least one recorded match');\n    }\n\n    // 2. Compare timestamps (use the LATEST of rating or stats)\n    const playerRatingTs = Number(player.ratingUpdatedAt || 0);\n    const playerStatsTs  = Number(player.statsUpdatedAt || 0);\n    const playerLatestTs = Math.max(playerRatingTs, playerStatsTs);\n    \n    const userRatingTs = Number(user?.rating_updated_at || 0);\n    const userStatsTs  = Number(user?.stats_updated_at || 0);\n    const userLatestTs = Math.max(userRatingTs, userStatsTs);\n    \n    if (playerLatestTs <= userLatestTs) {\n        throw new Error('Skip: data is not newer');\n    }\n\n    // 3. Derive day from statsUpdatedAt (fallback to today if missing)\n    const statsDate = playerStatsTs \n        ? new Date(playerStatsTs).toISOString().split('T')[0]\n        : new Date().toISOString().split('T')[0];\n\n    return {\n        player_day: `${player.userId}@${statsDate}`,\n        player: player.userId,\n        day: statsDate,\n        wins: player.wins || 0,\n        losses: player.losses || 0,\n        rating: player.rating || 1500,\n        stats_updated_at: playerStatsTs,\n        rating_updated_at: playerRatingTs\n    };\n};"
        },
        "resolve": "3118305f-7081-467f-852b-cc17eb52cf75",
        "reject": null
      },
